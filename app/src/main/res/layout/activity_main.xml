<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/softGrayBG"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Registro de Pedido"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Info icon decorativo -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_photo_box">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="i"
                android:textSize="16sp"
                android:textStyle="bold|italic"
                android:textColor="@color/primaryTeal" />
        </FrameLayout>
    </LinearLayout>

    <!-- btnVolver oculto (requerido por Kotlin) -->
    <ImageButton
        android:id="@+id/btnVolver"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:contentDescription="Volver" />

    <!-- Contenido scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Boton QR: fondo blanco, borde dashed azul -->
            <LinearLayout
                android:id="@+id/btnLeerQR"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_dashed_qr"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/primaryTeal"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="QR" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leer QR"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryTeal" />
            </LinearLayout>

            <!-- Seccion: CLIENTE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLIENTE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Input: Nombre del cliente -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombre"
                style="@style/FormInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del cliente"
                app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:startIconTint="@color/slate_400"
                app:boxBackgroundColor="@color/white"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Input: Telefono -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTelefono"
                style="@style/FormInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Telefono"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:startIconTint="@color/slate_400"
                app:boxBackgroundColor="@color/white"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelefono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Input: Direccion -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDireccion"
                style="@style/FormInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Direccion / Referencia"
                app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                app:startIconTint="@color/slate_400"
                app:boxBackgroundColor="@color/white"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:inputType="textMultiLine"
                    android:minLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Input: Detalle del pedido -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDetalle"
                style="@style/FormInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Detalle del pedido"
                app:startIconDrawable="@android:drawable/ic_menu_agenda"
                app:startIconTint="@color/slate_400"
                app:boxBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDetallePedido"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:inputType="textMultiLine"
                    android:minLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Seccion: FOTOGRAFIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOTOGRAFIA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Caja de Fotografia animada -->
            <LinearLayout
                android:id="@+id/btnTomarFoto"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_photo_box"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivFotoIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/accentOrange"
                    android:contentDescription="Camara"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvFotoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomar fotografia"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryTeal" />
            </LinearLayout>

            <!-- Preview de foto -->
            <ImageView
                android:id="@+id/ivFotoPreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:contentDescription="Vista previa" />

            <!-- Seccion: PAGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO DE PAGO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgTipoPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:background="@drawable/toggle_unselected_bg"
                android:padding="4dp">

                <RadioButton
                    android:id="@+id/rbEfectivo"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Efectivo"
                    android:gravity="center"
                    android:button="@null"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:checked="true"
                    android:background="@drawable/toggle_selected_bg"
                    android:textColor="@color/primaryTeal"
                    android:elevation="2dp" />

                <RadioButton
                    android:id="@+id/rbTransferencia"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Transferencia"
                    android:gravity="center"
                    android:button="@null"
                    android:textSize="13sp"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_secondary" />
            </RadioGroup>

            <!-- Boton Guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="GUARDAR PEDIDO"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                app:backgroundTint="@color/successGreen"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconTint="@color/white"
                app:cornerRadius="18dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>