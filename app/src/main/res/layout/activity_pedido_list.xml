<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/softGrayBG"
    android:fitsSystemWindows="true"
    tools:context=".PedidoListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <!-- Titulo a la izquierda -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panel de"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tus "
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pedidos"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/accentOrange" />
                </LinearLayout>
            </LinearLayout>

            <!-- Boton Cerrar Sesion -->
            <LinearLayout
                android:id="@+id/btnCerrarSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_logout_btn"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/logout_red"
                        android:contentDescription="Logout" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CERRAR SESIÓN"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/logout_red"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>

        <!-- Separador header / acciones -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#E2E8F0" />

        <!-- Acciones Rapidas: CSV + SYNC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Boton CSV -->
            <LinearLayout
                android:id="@+id/btnExportarCSV"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_logo_teal"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/accentOrange"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="CSV" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CSV"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Boton SYNC -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSincronizar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="SYNC"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:icon="@android:drawable/stat_notify_sync"
                app:iconTint="@color/accentOrange"
                app:iconGravity="textStart"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#E2E8F0" />

        <!-- Progress oculto (requerido por Kotlin) -->
        <ProgressBar
            android:id="@+id/progressDashboard"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:visibility="gone" />

        <!-- Lista vacia -->
        <TextView
            android:id="@+id/tvVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="No hay pedidos registrados"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingTop="48dp"
            android:visibility="gone" />

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPedidos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingBottom="90dp" />

    </LinearLayout>

    <!-- Botones flotantes inferiores centrados -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Boton Ruta: cuadrado blanco -->
        <ImageButton
            android:id="@+id/btnVerRuta"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_ruta"
            android:src="@android:drawable/ic_menu_mapmode"
            android:scaleType="centerInside"
            android:elevation="0dp"
            app:tint="@color/primaryTeal"
            android:contentDescription="Ver ruta"
            android:layout_marginEnd="12dp" />

        <!-- FAB Nuevo Pedido: circular naranja -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNuevoPedido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Nuevo pedido"
            app:fabSize="normal"
            app:backgroundTint="@color/accentOrange"
            app:tint="@color/white"
            app:elevation="0dp" />
    </LinearLayout>

</FrameLayout>
